# Path to Tesseract binary (leave as 'tesseract' if in PATH)
# Windows: C:\Program Files\Tesseract-OCR\tesseract.exe
# Linux/Mac: /usr/bin/tesseract  (usually auto-detected)
TESSERACT_CMD=tesseract

# Sentence-transformers model for policy chunk embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2

# FAISS L2 distance cutoff (lower = stricter matching)
FAISS_SIMILARITY_THRESHOLD=1.2

# Set to true to use Claude claude-haiku-4-5-20251001 for summaries
# Requires ANTHROPIC_API_KEY to be set
USE_LLM_SUMMARY=false

# Only needed if USE_LLM_SUMMARY=true
# ANTHROPIC_API_KEY=your-key-here

# Directory for storing processed claim JSON files
STORAGE_DIR=storage

# Directory for storing generated PDF reports
REPORTS_DIR=reports
