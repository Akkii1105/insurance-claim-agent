# ── Application Settings ──
APP_NAME=Insurance Claim Settlement Agent
APP_ENV=development
DEBUG=true

# ── Server ──
HOST=0.0.0.0
PORT=8000

# ── Paths ──
DATA_DIR=./data
STORAGE_DIR=./storage
REPORTS_DIR=./reports

# ── OCR (Tesseract) ──
# Windows: C:\Program Files\Tesseract-OCR\tesseract.exe
# Linux/Mac: /usr/bin/tesseract  (usually auto-detected)
TESSERACT_CMD=

# ── Poppler (required by pdf2image) ──
# Windows: C:\poppler\bin  (download from: https://github.com/oschwartz10612/poppler-windows/releases)
# Linux: apt-get install poppler-utils
# Mac: brew install poppler
POPPLER_PATH=

# ── Embedding Model ──
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── FAISS Settings ──
FAISS_INDEX_DIR=./storage/faiss_indexes
SIMILARITY_THRESHOLD=0.45
TOP_K_RESULTS=5
