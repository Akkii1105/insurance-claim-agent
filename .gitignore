# Python
__pycache__/
*.pyc
*.pyo
*.py[cod]
*.egg-info/
dist/
build/
*.egg

# Virtual environment
venv/
.venv/
env/

# Environment variables (NEVER commit secrets)
.env

# IDE
.vscode/
.idea/
*.swp
*.swo

# Test caches
.pytest_cache/
htmlcov/
.coverage

# Runtime storage (generated at runtime — not committed)
storage/claims/
reports/

# FAISS index files (generated at runtime)
*.faiss
storage/faiss_indexes/*.index
storage/faiss_indexes/*.pkl

# OS artifacts
.DS_Store
Thumbs.db

# NOTE: data/synthetic/ is intentionally NOT ignored — test data must be committed
# NOTE: .env.example is intentionally NOT ignored — template must be committed
